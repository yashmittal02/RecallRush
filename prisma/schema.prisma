generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  name         String?
  email        String        @unique
  password     String
  xp           Int           @default(0)
  level        Int           @default(1)
  gameSessions GameSession[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model GameSession {
  id           String   @id @default(uuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  title        String   @default("Untitled Game")
  score        Int
  accuracy     Float
  timeSpent    Int
  notesContent String?
  mistakes     String?  // JSON stringified array of { question, correct }
  createdAt    DateTime @default(now())
}
